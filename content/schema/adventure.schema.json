{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "adventure.schema.json",
  "title": "EurekaCub Adventure Schema",
  "type": "object",
  "required": ["id", "title", "group_tag", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique adventure identifier"
    },
    "title": {
      "type": "object",
      "required": ["zh", "en"],
      "properties": {
        "zh": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "group_tag": {
      "type": "string",
      "description": "Tag for grouping related adventures"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scenario", "module_ids", "puzzle_type", "data"],
        "properties": {
          "scenario": {
            "type": "object",
            "required": ["zh", "en"],
            "properties": {
              "zh": { "type": "string", "minLength": 1 },
              "en": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "module_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Puzzle IDs used in this stage"
          },
          "puzzle_type": {
            "type": "string",
            "description": "Type of puzzle interaction for this stage"
          },
          "data": {
            "type": "object",
            "description": "Stage-specific configuration data"
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "created": { "type": "string" },
        "reviewed": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
