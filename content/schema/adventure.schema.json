{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "adventure.schema.json",
  "title": "EurekaCub Adventure Schema",
  "type": "object",
  "required": ["id", "title", "category", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique adventure identifier"
    },
    "title": {
      "type": "object",
      "required": ["zh", "en"],
      "properties": {
        "zh": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "category": {
      "type": "string",
      "enum": ["life", "challenger", "ultimate", "sports", "science"],
      "description": "Adventure category for grouping"
    },
    "icon": {
      "type": "string",
      "description": "Emoji icon for the adventure"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "age_target": {
      "type": "string",
      "description": "Target age range (e.g. 6+, 9+)"
    },
    "modules_used": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Module IDs used in this adventure"
    },
    "unlock_condition": {
      "type": ["string", "null"],
      "description": "Condition to unlock this adventure (null = always available)"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "narrative", "character", "puzzle_module", "puzzle_id"],
        "properties": {
          "id": { "type": "string" },
          "narrative": {
            "type": "object",
            "required": ["zh", "en"],
            "properties": {
              "zh": { "type": "string", "minLength": 1 },
              "en": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "character": {
            "type": "string",
            "description": "Character emoji for this stage"
          },
          "puzzle_module": {
            "type": "string",
            "description": "Module renderer to use"
          },
          "puzzle_id": {
            "type": "string",
            "description": "Puzzle content ID to load"
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "created": { "type": "string" },
        "reviewed": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
