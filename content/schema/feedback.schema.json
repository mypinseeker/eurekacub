{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feedback.schema.json",
  "title": "EurekaCub Feedback Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["category", "context", "message"],
    "properties": {
      "category": {
        "type": "string",
        "enum": ["correct", "error", "hint", "aha", "encourage"],
        "description": "Feedback category type"
      },
      "context": {
        "type": "string",
        "description": "When this feedback should be shown (e.g., 'first-correct', 'retry-3')"
      },
      "message": {
        "type": "object",
        "required": ["zh", "en"],
        "properties": {
          "zh": { "type": "string", "minLength": 1 },
          "en": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
